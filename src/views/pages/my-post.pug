extends ../layouts/master.pug

block title
  title Amico | Мои объявления

block basicSeo
  meta(content="Мои объявления" name="description")
  meta(content="Мои объявления" name="keywords")

block manifestBrowserconfigFiles
  link(href="../manifest.json" rel="manifest" crossorigin)
  meta(content="../browserconfig.xml" name="msapplication-config")

block content
  main.page-my-post.hasMobMenu
    .page-container
      include ../components/menu.pug
      include ../components/my-post.pug
      include ../components/my-post-popup.pug
    include ../components/footer.pug
    include ../components/menu-mobile.pug