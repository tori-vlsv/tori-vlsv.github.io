doctype html
html(lang="ru")
  head
    meta(charset="UTF-8")
    meta(
      content="width=device-width, initial-scale=1, maximum-scale=1"
      name="viewport"
    )
    meta(content="ie=edge" http-equiv="X-UA-Compatible")

    meta(content="#ffc40d" name="msapplication-TileColor")
    meta(content="#ffffff" name="theme-color")

    block basicSeo
      meta(content="Amico" name="description")
      meta(content="Amico" name="keywords")
      meta(content="wotkad" name="author")

    meta(content="summary" name="twitter:card")
    meta(content="" name="twitter:description")
    meta(content="" name="twitter:image")

    meta(content="Amico" property="og:title")
    meta(content="" property="og:description")
    meta(content="" property="og:image")

    link(
      href="/assets/images/favicons/apple-touch-icon.png"
      rel="apple-touch-icon"
      sizes="180x180"
    )
    link(
      href="/assets/images/favicons/android-chrome-192x192.png"
      rel="icon"
      sizes="192x192"
      type="image/png"
    )
    link(
      href="/assets/images/favicons/favicon-32x32.png"
      rel="icon"
      sizes="32x32"
      type="image/png"
    )
    link(
      href="/assets/images/favicons/favicon-16x16.png"
      rel="icon"
      sizes="16x16"
      type="image/png"
    )
    link(href="/assets/images/favicons/favicon.ico" rel="shortcut icon")
    link(
      color="#5bbad5"
      href="/assets/images/favicons/safari-pinned-tab.svg"
      rel="mask-icon"
    )

    block title
      title Amico | Страница без названия

    block manifestBrowserconfigFiles
      link(href="./manifest.json" rel="manifest" crossorigin)
      meta(content="./browserconfig.xml" name="msapplication-config")

    script.
      function autorun() {}
      if (window.addEventListener) window.addEventListener("load", autorun, false);
      else window.onload = autorun;
    noscript.
      Похоже у вас отключён Javascript, поэтому вы видете это сообщение.

    link(
      href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css"
      rel="stylesheet"
      crossorigin=""
      integrity="sha256-kLaT2GOSpHechhsozzB+flnD+zUyjE2LlfWPgU04xyI="
    )
    script(
      src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"
      crossorigin=""
      integrity="sha256-WBkoXOwTeyKclOHuWtc+i2uENFpDZ9YPdf5Hf+D7ewM="
    )
    script(
      src="https://cdnjs.cloudflare.com/ajax/libs/leaflet-geosearch/3.8.0/bundle.min.js"
    )

  body
    .render

    include ../components/header.pug

    block content

    include ../components/signin.pug

    .bg

    .popup-bg

    include ../components/profile-edit.pug
    include ../components/delete-profile.pug

    block js