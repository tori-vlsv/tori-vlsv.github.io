extends ./layouts/master.pug

block title
  title Amico | Главная

block basicSeo
  meta(content="Главная страница" name="description")
  meta(content="Главная, страница" name="keywords")

block manifestBrowserconfigFiles
  link(href="./manifest.json" rel="manifest" crossorigin)
  meta(content="./browserconfig.xml" name="msapplication-config")

block content
  main.page-index.hasMobMenu
    .page-container
      include ./components/search-main.pug
      include ./components/header-mobile.pug
      include ./components/categories.pug
      include ./components/recommendations.pug
      include ./components/category-popup.pug
    include ./components/footer.pug
    include ./components/menu-mobile.pug