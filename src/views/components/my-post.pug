include ../mixins/card.pug
.profile
  .wrapper
    .page-layout
      aside.profile__sidebar
        .profile__sidebar__sticky
          .profile__sidebar__header
            img.profile__sidebar__photo(
              src="/assets/images/avatar-big.png"
              alt="avatar-big"
            )
            .profile__sidebar__title Regina Miles
            include ../components/rating.pug
          .profile__sidebar__links
            a.profile__sidebar__link(href="#") My announcements
            a.profile__sidebar__link(href="#") Favorites
            a.profile__sidebar__link(href="#") Messages
          .profile__sidebar__links
            a.profile__sidebar__link(href="#") Settings
            a.profile__sidebar__link.profile__sidebar__link-gray(href="#") Exit
      .profile__content
        h1.page__title.profile__title My post
        .profile__states
          .profile__states__inner
            a.profile__state.active(href="#")
              p Waiting for action
              span 4
            a.profile__state(href="#")
              p Archive
              span 4
          .sorting.sorting-blue.profile__sorting
            button.sorting__filter(type="button")
              input(type="text" name="sorting")
              span Selected all
              img(
                src="/assets/images/icons/arrow-down-blue.svg"
                alt="arrow-down-blue"
              )
            .sorting__choose
              .sorting__title Show first
              .sorting__choose__item.active(data-value="nothing") Nothing
              .sorting__choose__item(data-value="select_all") Select all
              .sorting__choose__item(data-value="active") Active
              .sorting__choose__item(data-value="disabled") Inactive
        .grid-categories__grid.profile__cards.active
          .edit__cards
            .edit__cards__count
              span#counter-posts 0
              span announcement
            .edit__cards__buttons
              button.edit__cards__button(type="button")
                img(src="/assets/images/icons/focus-blue.svg" alt="focus-blue")
                span Post
              button.edit__cards__button(type="button")
                img(
                  src="/assets/images/icons/to-archive-blue.svg"
                  alt="to-archive-blue"
                )
                span To the archive
              button.edit__cards__button(type="button")
                img(src="/assets/images/icons/trash-blue.svg" alt="trash-blue")
                span Delete
          +card('#', '/assets/images/recommendations/item-2.png','item-2', 'Kitty', 'Free', '200,000 km, 3.5 AT (280 hp),SUV, full, petrol <br> Not on the move requires engine replacement.', 'Pets', '<span>Rattanakosin</span> 12 minutes', '1 day ago', true, false)
          +card('#', '/assets/images/recommendations/item-3.png','item-3', 'Infiniti fx35 (2005)', '300 626 ฿', 'The shoes are new. <br> Size 39. <br> Genuine leather.The size didn\'t fit. <br> In the native box.', 'Car & Vehicles', '<span>Chatuchak</span> 30 minutes', '1 hours ago', true, false)
          +card('#', '/assets/images/recommendations/item-7.png','item-7', 'Comics collection', '15 000 ฿', 'Comics of the Marvel universe are on sale. <br> In excellent condition. All pages are as new without creases and scuffs. <br> Purchased in a personal collection of comics.', 'Collecting', '<span>BangPhlat</span> 5 minutes', '20 hours ago', true, true)
button.profile__place-an-ad(type="button")
  svg(
    fill="none"
    viewBox="0 0 20 20"
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
  )
    path(
      d="M10 6V14"
      stroke="white"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.5"
    )
    path(
      d="M14 10L6 10"
      stroke="white"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.5"
    )
  span Place an ad