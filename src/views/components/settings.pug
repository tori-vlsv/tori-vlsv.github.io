                button.settings__knob.settings__change(type="button")
                  span Change password
                form.settings__popup.settings__popup-password.profile-edit.profile-edit__change(
                  action="#"
                )
                  .settings__popup__step.active
                    .mobile__header
                      .settings__close
                        img.chat__header__icon(
                          src="/assets/images/icons/arrow-left-blue.svg"
                          alt="arrow-left-blue"
                        )
                    .settings__popup__title Create a new password
                    .settings__subtitle-small Write a new password
                    .settings__inputs
                      .settings__input.settings__input__password.settings__popup__buttons
                        input(
                          type="password"
                          placeholder="New password"
                          name="current-password"
                          required
                        )
                        img.settings__input__icon.password-show(
                          src="/assets/images/icons/eyeslash.svg"
                          alt="eyeslash"
                        )
                        img.settings__input__icon.symbols-show(
                          src="/assets/images/icons/eye.svg"
                          alt="eye"
                        )
                      .settings__input.settings__input__password
                        input(
                          type="password"
                          placeholder="Repeat the password"
                          name="new-password"
                          required
                        )
                        img.settings__input__icon.password-show(
                          src="/assets/images/icons/eyeslash.svg"
                          alt="eyeslash"
                        )
                        img.settings__input__icon.symbols-show(
                          src="/assets/images/icons/eye.svg"
                          alt="eye"
                        )
                    .settings__popup__buttons
                      button.settings__button-disabled.settings__button-next.settings__button.settings__button-active.settings__button-confirm(
                        type="submit"
                      ) Change
                button.settings__knob(type="button")
                  span Exit
              table
                tr
                  td Name
                  td Regina Miles
                    button.settings__snap.settings__change-name(type="button") Сhange
                    form.settings__open(action="#")
                      .settings__buttons
                        .settings__input
                          input(
                            type="text"
                            placeholder="Enter your name"
                            name="name"
                            required
                          )
                        button.settings__snap.settings__save(type="submit") Save
                tr
                  td Email
                  td ReginaMiles@gmail.com
                    button.settings__snap.settings__change(type="button") Сhange
                    form.settings__popup.settings__popup-mail(action="#")
                      .settings__popup__step.settings__popup__first.active
                        .settings__popup__title Change Email
                        .settings__close <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="40" height="40" rx="6" fill="white"/><path d="M26.5 14.002L13.9987 26.5033" stroke="#1D5BFB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M26.5 26.502L13.9987 14.0006" stroke="#1D5BFB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        input.error(
                          type="email"
                          placeholder="Enter your email"
                          name="email"
                          required
                        )
                        span.error-text The email address you entered is already in use
                        .settings__popup__buttons
                          button.settings__button-next.settings__button.settings__button-active(
                            type="button"
                          ) Save
                      .settings__popup__step.settings__popup__second
                        .settings__popup__title Confirm email change
                        .settings__close <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="40" height="40" rx="6" fill="white"/><path d="M26.5 14.002L13.9987 26.5033" stroke="#1D5BFB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M26.5 26.502L13.9987 14.0006" stroke="#1D5BFB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        .settings__popup__text Enter the code that will come to your mail <span id="settings-email">ReginaMiles@gmail.com</span>
                        input(
                          type="text"
                          placeholder="Email code"
                          name="email-confirm"
                          required
                        )
                        .settings__popup__buttons
                          button.settings__button-back.settings__button.settings__button-white(
                            type="button"
                          ) Сhange email
                          button.settings__button-next.settings__button.settings__button-active.settings__button-confirm(
                            type="submit"
                          ) Сonfirm
                      .settings__popup__step.settings__popup__third
                        .settings__popup__title Confirm email change
                        .settings__close <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="40" height="40" rx="6" fill="white"/><path d="M26.5 14.002L13.9987 26.5033" stroke="#1D5BFB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M26.5 26.502L13.9987 14.0006" stroke="#1D5BFB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        .settings__popup__text A letter was sent to <br><span>ReginaMiles@gmail.com</span> <br> - open it and confirm the change of address. If there is no email, check Spam
                tr
                  td Phone
                  td +66 123 456-78-90
                    button.settings__snap.settings__change(type="button") Сhange
                    form.settings__popup.settings__popup-tel(action="#")
                      .settings__popup__step.settings__popup__first.active
                        .settings__popup__title Adding a number
                        .settings__close <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="40" height="40" rx="6" fill="white"/><path d="M26.5 14.002L13.9987 26.5033" stroke="#1D5BFB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M26.5 26.502L13.9987 14.0006" stroke="#1D5BFB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        input(
                          type="tel"
                          placeholder="+66 ___ ___-__-__"
                          required
                        )
                        .settings__popup__buttons
                          button.settings__button-next.settings__button.settings__button-active(
                            type="button"
                          ) Save
                      .settings__popup__step.settings__popup__second
                        .settings__popup__title Number confirmation
                        .settings__close <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="40" height="40" rx="6" fill="white"/><path d="M26.5 14.002L13.9987 26.5033" stroke="#1D5BFB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M26.5 26.502L13.9987 14.0006" stroke="#1D5BFB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        .settings__popup__text Enter the code that will come to the number <span id="settings-tel">+66 123 456-78-90</span> within 2 minutes.
                        input(type="text" placeholder="SMS code" required)
                        .settings__popup__buttons
                          button.settings__button-back.settings__button.settings__button-white(
                            type="button"
                          ) Сhange number
                          button.settings__button-next.settings__button.settings__button-active.settings__button-confirm(
                            type="submit"
                          ) Сonfirm
