.profile.settings
  .wrapper
    .page-layout
      aside.profile__sidebar
        .profile__sidebar__sticky
          .profile__sidebar__header
            .profile__sidebar__img
              img.profile__sidebar__photo(
                src="/assets/images/avatar-big.png"
                alt="avatar-big"
              )
              label.profile__upload.profile__upload-main
                input(type="file" accept="image/png, image/gif, image/jpeg")
            .profile__sidebar__title Regina Miles
            include ../components/rating.pug
          .profile__sidebar__links
            a.profile__sidebar__link(href="#") My announcements
            a.profile__sidebar__link(href="#") Favorites
            a.profile__sidebar__link(href="#") Messages
          .profile__sidebar__links
            a.profile__sidebar__link(href="#") Settings
            a.profile__sidebar__link.profile__sidebar__link-gray(href="#") Exit
      .profile__content
        h1.page__title.profile__title Settings
        .profile__block
          .settings__blocks
            .settings__block
              h2.settings__untitle Profile settings
              .settings__mobile
                .profile__block
                  .profile__sidebar__header
                    .profile__sidebar__left
                      .profile__sidebar__title Regina Miles
                      span.settings__subtitle Individual, user number - 1
                      include ../components/rating.pug
                    .profile__sidebar__img
                      img.profile__sidebar__photo(
                        src="/assets/images/avatar-big.png"
                        alt="avatar-big"
                      )
                  .settings__data
                    img.settings__data__photo(
                      src="/assets/images/icons/mail.svg"
                      alt="mail"
                    )
                    p ReginaMiles@gmail.com
                  .settings__data
                    img.settings__data__photo(
                      src="/assets/images/icons/calendar.svg"
                      alt="calendar"
                    )
                    p ReginaMiles@gmail.com
                  button.settings__button.settings__button-active.settings__profile__edit(
                    type="button"
                  ) Edit profile
                .profile__block
                  h3 My post
                  .settings__data
                    img.settings__data__photo(
                      src="/assets/images/icons/ads.svg"
                      alt="ads"
                    )
                    p 2 active ads
                  a.settings__button.settings__button-active(href="/my-post") Go to ads
                .profile__block
                  h3 My reviews
                  .settings__data
                    img.settings__data__photo(
                      src="/assets/images/icons/star-active.svg"
                      alt="star-active"
                    )
                    p 2 active ads
                  a.settings__button.settings__button-active(href="/reviews") Go to my reviews
                .profile__block
                  h3 Contact Information
                  .settings__data
                    img.settings__data__photo(
                      src="/assets/images/icons/pin.svg"
                      alt="pin"
                    )
                    p 2 City: Bangkok
                  button.settings__change.settings__button.settings__button-active(
                    type="button"
                  ) Choose another
