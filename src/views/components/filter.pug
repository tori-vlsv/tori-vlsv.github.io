        .filter__search__input
          img.filter__search__icon(
            src="/assets/images/icons/search.svg"
            alt="search"
          )
          input(type="search" placeholder="Search" name="search")
      .filter__labels.custom-scroll
        label.filter__label
          input.filter__input(
            type="checkbox"
            checked
            name="adidas"
            value="Adidas"
          )
          span.filter__checkbox Adidas
        label.filter__label
          input.filter__input(type="checkbox" name="nike" value="Nike")
          span.filter__checkbox Nike
        label.filter__label
          input.filter__input(type="checkbox" name="rebook" value="Rebook")
          span.filter__checkbox Rebook
        label.filter__label
          input.filter__input(type="checkbox" name="puma" value="Puma")
          span.filter__checkbox Puma
        label.filter__label.filter__label-hidden
          input.filter__input(
            type="checkbox"
            name="one_more_item"
            value="One more item"
          )
          span.filter__checkbox One more item
      button.filter__showall(type="button") Show all
