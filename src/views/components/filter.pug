form.filter(action="#")
  .filter__header
    button.filter__back(type="button")
      img(src="/assets/images/icons/arrow-left-blue.svg" alt="arrow-left-blue")
    .filter__header__text Filters
    button.filter__header__reset(type="button") Reset
  .filter__item
    .filter__title
      h3 Price
    .filter__block
      .filter__range
        .filter__range__values
          .filter__range__value From
            .lower-value
            input#lower-value(type="text" name="price_from")
          .filter__range__value To
            .upper-value
            input#upper-value(type="text" name="price_to")
        .filter__range__slider
  .filter__item
    .filter__title
      h3 Condition
      button.filter__reset(type="button") Reset all
      img.filter__toggle(
        src="/assets/images/icons/arrow-down-blue.svg"
        alt="arrow-down-blue"
      )
    .filter__block
      .filter__labels.custom-scroll
        label.filter__label
          input.filter__input(
            type="checkbox"
            checked
            name="new_with_tags"
            value="New with tags"
          )
          span.filter__checkbox New with tags
        label.filter__label
          input.filter__input(
            type="checkbox"
            name="new_with_defects"
            value="New with defects"
          )
          span.filter__checkbox New with defects
        label.filter__label
          input.filter__input(
            type="checkbox"
            name="pre_owned"
            value="Pre-owned"
          )
          span.filter__checkbox Pre-owned
        label.filter__label
          input.filter__input(
            type="checkbox"
            name="not_specified"
            value="Not Specified"
          )
          span.filter__checkbox Not Specified
  .filter__item
    .filter__title
      h3 Brand
      button.filter__reset(type="button") Reset all
      img.filter__toggle(
        src="/assets/images/icons/arrow-down-blue.svg"
        alt="arrow-down-blue"
      )
    .filter__block
