mixin message(href, src, alt, name, createdAt, title, price, message, isUnread)
  .message
    label
      if isUnread
        input.message__checker(
          type="checkbox"
          name="" + alt
          data-status="unread"
        )
      else
        input.message__checker(
          type="checkbox"
          name="" + alt
          data-status="read"
        )
      .message__info
        .message__options.sorting
          button.sorting__filter(type="button")
            input(type="text" name="sorting")
            img(src="/assets/images/icons/dots-blue.svg" alt="dots-blue")
          .sorting__choose
            .chat__menu__block
              a.chat__menu__item(href="#")
                img.chat__menu__pic(
                  src="/assets/images/chat/item-1.png"
                  alt="item-1"
                )
                span Go to the ad
              a.chat__menu__item(href="#")
                img.chat__menu__pic(
                  src="/assets/images/chat/item-2.png"
                  alt="item-2"
                )
                span Go to profile
            .chat__menu__block
              a.chat__menu__item.chat__menu__select(href="#")
                .chat__menu__icon <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15.875 9L10.625 14.2498L8 11.625" stroke="#1A2030" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><rect x="0.5" y="0.5" width="23" height="23" rx="1.5" stroke="#1A2030"/></svg>
                span Select
              a.chat__menu__item(href="#")
                .chat__menu__icon <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M4 3.75C3.86193 3.75 3.75 3.86193 3.75 4V20C3.75 20.1381 3.86192 20.25 4 20.25H20C20.1381 20.25 20.25 20.1381 20.25 20V13C20.25 12.5858 20.5858 12.25 21 12.25C21.4142 12.25 21.75 12.5858 21.75 13V20C21.75 20.9665 20.9665 21.75 20 21.75H4C3.03351 21.75 2.25 20.9665 2.25 20V4C2.25 3.0335 3.0335 2.25 4 2.25H11C11.4142 2.25 11.75 2.58579 11.75 3C11.75 3.41421 11.4142 3.75 11 3.75H4Z" fill="#1A2030"/><path fill-rule="evenodd" clip-rule="evenodd" d="M17.3474 2.25C17.5464 2.24996 17.7373 2.32903 17.878 2.46979L21.5304 6.12384C21.8232 6.4167 21.8232 6.8914 21.5304 7.18426L11.189 17.5302C11.0484 17.6709 10.8576 17.75 10.6586 17.75H7C6.58579 17.75 6.25 17.4142 6.25 17V13.36C6.25 13.1612 6.32889 12.9706 6.46935 12.8299L16.8169 2.46999C16.9575 2.32918 17.1484 2.25004 17.3474 2.25ZM17.3478 4.06109L7.75 13.6703V16.25H10.3478L19.9396 6.65405L17.3478 4.06109Z" fill="#1A2030"/></svg>
                span Leave a comment
              a.chat__menu__item(href="#")
                .chat__menu__icon <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M1.25 3C1.25 2.58579 1.58579 2.25 2 2.25H17C17.4142 2.25 17.75 2.58579 17.75 3C17.75 3.41421 17.4142 3.75 17 3.75H2.75V17.25H9.5C9.69891 17.25 9.88968 17.329 10.0303 17.4697L12 19.4393L13.9697 17.4697C14.1103 17.329 14.3011 17.25 14.5 17.25H21.25V8C21.25 7.58579 21.5858 7.25 22 7.25C22.4142 7.25 22.75 7.58579 22.75 8V18C22.75 18.4142 22.4142 18.75 22 18.75H14.8107L12.5303 21.0303C12.2374 21.3232 11.7626 21.3232 11.4697 21.0303L9.18934 18.75H2C1.58579 18.75 1.25 18.4142 1.25 18V3Z" fill="#1A2030"/><path fill-rule="evenodd" clip-rule="evenodd" d="M10.75 10C10.75 9.58579 11.0858 9.25 11.5 9.25H12.5013C12.9155 9.25 13.2513 9.58579 13.2513 10C13.2513 10.4142 12.9155 10.75 12.5013 10.75H11.5C11.0858 10.75 10.75 10.4142 10.75 10Z" fill="#1A2030"/><path fill-rule="evenodd" clip-rule="evenodd" d="M15.75 10C15.75 9.58579 16.0858 9.25 16.5 9.25H17.4995C17.9137 9.25 18.2495 9.58579 18.2495 10C18.2495 10.4142 17.9137 10.75 17.4995 10.75H16.5C16.0858 10.75 15.75 10.4142 15.75 10Z" fill="#1A2030"/><path fill-rule="evenodd" clip-rule="evenodd" d="M5.75 10C5.75 9.58579 6.08579 9.25 6.5 9.25H7.49945C7.91366 9.25 8.24945 9.58579 8.24945 10C8.24945 10.4142 7.91366 10.75 7.49945 10.75H6.5C6.08579 10.75 5.75 10.4142 5.75 10Z" fill="#1A2030"/><path d="M21.5 5C22.3284 5 23 4.32843 23 3.5C23 2.67157 22.3284 2 21.5 2C20.6716 2 20 2.67157 20 3.5C20 4.32843 20.6716 5 21.5 5Z" fill="#1A2030"/></svg>
                span Mark as Unread
            .chat__menu__block.chat__menu__delete.message__delete
              a.chat__menu__item(href="#")
                .chat__menu__icon <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 6L4 6.00001" stroke="#1A2030" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/><path d="M10 11V16" stroke="#1A2030" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/><path d="M14 11V16" stroke="#1A2030" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/><rect x="5.75" y="6.75" width="12.5" height="13.5" stroke="#1A2030" stroke-width="1.5"/><rect x="7.75" y="2.75" width="8.5" height="3.5" stroke="#1A2030" stroke-width="1.5"/></svg>
                span Delete Chat
      .message__inner
        .message__img
          .message__img__inner
            img(src="" + src alt="" + alt)
          .message__author
            img(src="/assets/images/message-author.png" alt="message-author")
        .message__content
          .message__header
            .message__row
              a.message__name(href="" + href)= name
              .message__createdAt= createdAt
            .message__row
              .message__title= title
              .message__price= price
          .message__footer
            .message__text= message
            if isUnread
              .message__status